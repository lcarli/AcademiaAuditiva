@{
    ViewData["Title"] = Localizer["Admin.Home.Title"].Value;
    var stats = new (string Label, object Value, string Icon, string Color)[] {
        (Localizer["Admin.Users"].Value,      ViewBag.UserCount,      "bi-people",       "#7c3aed"),
        (Localizer["Admin.Admins"].Value,     ViewBag.AdminCount,     "bi-shield-lock",  "#ec4899"),
        (Localizer["Admin.Teachers"].Value,   ViewBag.TeacherCount,   "bi-mortarboard",  "#3b82f6"),
        (Localizer["Admin.Students"].Value,   ViewBag.StudentCount,   "bi-person-check", "#14b8a6"),
        (Localizer["Admin.Classrooms"].Value, ViewBag.ClassroomCount, "bi-easel",        "#f59e0b"),
        (Localizer["Admin.Routines"].Value,   ViewBag.RoutineCount,   "bi-list-check",   "#10b981"),
    };
}

<header class="mb-4">
    <span class="aa-badge-soft">@Localizer["Admin.Home.Title"]</span>
    <h1 class="display-6 fw-bold mt-2 mb-1 text-body-emphasis">@Localizer["Admin.Home.Title"]</h1>
    <p class="text-secondary mb-0">@Localizer["Admin.Home.Subtitle"]</p>
</header>

<div class="row g-4">
    @foreach (var s in stats)
    {
        <div class="col-md-4 col-lg-3">
            <div class="aa-card aa-card-accent p-4 h-100">
                <span class="aa-icon-pill mb-3" aria-hidden="true" style="color:@s.Color"><i class="bi @s.Icon"></i></span>
                <div class="text-secondary small text-uppercase">@s.Label</div>
                <div class="display-6 fw-bold mb-0 text-body-emphasis">@s.Value</div>
            </div>
        </div>
    }
</div>
