@model AcademiaAuditiva.Models.Teaching.Classroom
@{
    ViewData["Title"] = Model.Name;
}
<div class="d-flex justify-content-between align-items-start mb-3">
    <div>
        <h1 class="h3 mb-1">@Model.Name</h1>
        @if (!string.IsNullOrEmpty(Model.Description))
        {
            <p class="text-muted mb-0">@Model.Description</p>
        }
    </div>
    <div>
        <a class="btn btn-outline-secondary" asp-action="Edit" asp-route-id="@Model.Id">Edit</a>
        <a class="btn btn-link" asp-action="Index">Back</a>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white">
                <strong>Members</strong>
                <span class="badge bg-secondary ms-2">@Model.Members.Count</span>
            </div>
            <ul class="list-group list-group-flush">
                @if (!Model.Members.Any())
                {
                    <li class="list-group-item text-muted">No members yet. Invite students from the panel on the right.</li>
                }
                else
                {
                    @foreach (var m in Model.Members.OrderBy(x => x.Student!.UserName))
                    {
                        <li class="list-group-item d-flex justify-content-between">
                            <span>@m.Student?.UserName</span>
                            <small class="text-muted">joined @m.JoinedAt.ToString("yyyy-MM-dd")</small>
                        </li>
                    }
                }
            </ul>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white"><strong>Pending invites</strong></div>
            <ul class="list-group list-group-flush">
                @{
                    var pending = Model.Invites.Where(i => i.AcceptedAt == null && i.ExpiresAt > DateTime.UtcNow).ToList();
                }
                @if (!pending.Any())
                {
                    <li class="list-group-item text-muted small">None</li>
                }
                else
                {
                    @foreach (var i in pending.OrderByDescending(x => x.CreatedAt))
                    {
                        <li class="list-group-item small">
                            @i.Email
                            <div class="text-muted">expires @i.ExpiresAt.ToString("yyyy-MM-dd")</div>
                        </li>
                    }
                }
            </ul>
            <div class="card-body">
                <button class="btn btn-sm btn-outline-primary" disabled title="Coming in next commit">Invite student</button>
            </div>
        </div>
    </div>
</div>
