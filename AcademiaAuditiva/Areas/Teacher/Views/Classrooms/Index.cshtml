@model IEnumerable<AcademiaAuditiva.Areas.Teacher.Models.ClassroomListItem>
@{
    ViewData["Title"] = Localizer["Teacher.Classrooms.Title"].Value;
    var includeArchived = (bool)(ViewBag.IncludeArchived ?? false);
}
<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <h1 class="h3 mb-0 text-body-emphasis">@Localizer["Teacher.Classrooms.Title"]</h1>
    <a class="btn aa-grad-btn" asp-action="Create"><i class="bi bi-plus-lg me-1" aria-hidden="true"></i>@Localizer["Teacher.Classrooms.NewBtn"]</a>
</div>
<form method="get" class="mb-3">
    <div class="form-check form-switch">
        <input class="form-check-input" type="checkbox" id="includeArchived" name="includeArchived" value="true"
               @(includeArchived ? "checked" : "") onchange="this.form.submit()" />
        <label class="form-check-label" for="includeArchived">@Localizer["Teacher.Classrooms.IncludeArchived"]</label>
    </div>
</form>

@if (!Model.Any())
{
    <div class="aa-card-flat p-4 text-center">
        <span class="aa-icon-pill mb-2" aria-hidden="true"><i class="bi bi-easel"></i></span>
        <p class="mb-2 text-secondary">@Localizer["Teacher.Classrooms.Empty"]</p>
        <a class="btn aa-grad-btn btn-sm" asp-action="Create"><i class="bi bi-plus-lg me-1" aria-hidden="true"></i>@Localizer["Teacher.Classrooms.CreateFirst"]</a>
    </div>
}
else
{
    <div class="aa-card-flat">
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th>@Localizer["Teacher.Classrooms.Col.Name"]</th>
                        <th>@Localizer["Teacher.Classrooms.Col.Members"]</th>
                        <th>@Localizer["Teacher.Classrooms.Col.PendingInvites"]</th>
                        <th>@Localizer["Teacher.Classrooms.Col.Created"]</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr class="@(item.IsArchived ? "text-secondary" : "")">
                            <td>
                                <a asp-action="Details" asp-route-id="@item.Id"><strong>@item.Name</strong></a>
                                @if (item.IsArchived) { <span class="badge bg-secondary ms-2">@Localizer["Teacher.Classrooms.Archived"]</span> }
                                @if (!string.IsNullOrEmpty(item.Description))
                                {
                                    <div class="small text-secondary">@item.Description</div>
                                }
                            </td>
                            <td>@item.MemberCount</td>
                            <td>@item.PendingInvites</td>
                            <td>@item.CreatedAt.ToString("yyyy-MM-dd")</td>
                            <td class="text-end">
                                <a class="btn btn-sm btn-outline-secondary" asp-action="Edit" asp-route-id="@item.Id">@Localizer["Teacher.Classrooms.Edit"]</a>
                                @if (!item.IsArchived)
                                {
                                    <form asp-action="Archive" asp-route-id="@item.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button class="btn btn-sm btn-outline-warning"
                                                onclick="return confirm('@Localizer["Teacher.Classrooms.ArchiveConfirm"]')">@Localizer["Teacher.Classrooms.Archive"]</button>
                                    </form>
                                }
                                else
                                {
                                    <form asp-action="Restore" asp-route-id="@item.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button class="btn btn-sm btn-outline-success">@Localizer["Teacher.Classrooms.Restore"]</button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
