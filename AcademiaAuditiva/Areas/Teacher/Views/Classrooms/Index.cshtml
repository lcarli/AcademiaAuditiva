@model IEnumerable<AcademiaAuditiva.Areas.Teacher.Models.ClassroomListItem>
@{
    ViewData["Title"] = "Classrooms";
    var includeArchived = (bool)(ViewBag.IncludeArchived ?? false);
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Classrooms</h1>
    <a class="btn btn-primary" asp-action="Create">+ New classroom</a>
</div>
<form method="get" class="mb-3">
    <div class="form-check form-switch">
        <input class="form-check-input" type="checkbox" id="includeArchived" name="includeArchived" value="true"
               @(includeArchived ? "checked" : "") onchange="this.form.submit()" />
        <label class="form-check-label" for="includeArchived">Include archived</label>
    </div>
</form>

@if (!Model.Any())
{
    <div class="alert alert-light border">
        You don't have any classrooms yet. <a asp-action="Create">Create your first one →</a>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table align-middle">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Members</th>
                    <th>Pending invites</th>
                    <th>Created</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr class="@(item.IsArchived ? "text-muted" : "")">
                        <td>
                            <a asp-action="Details" asp-route-id="@item.Id"><strong>@item.Name</strong></a>
                            @if (item.IsArchived) { <span class="badge bg-secondary ms-2">Archived</span> }
                            @if (!string.IsNullOrEmpty(item.Description))
                            {
                                <div class="small text-muted">@item.Description</div>
                            }
                        </td>
                        <td>@item.MemberCount</td>
                        <td>@item.PendingInvites</td>
                        <td>@item.CreatedAt.ToString("yyyy-MM-dd")</td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-secondary" asp-action="Edit" asp-route-id="@item.Id">Edit</a>
                            @if (!item.IsArchived)
                            {
                                <form asp-action="Archive" asp-route-id="@item.Id" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button class="btn btn-sm btn-outline-warning"
                                            onclick="return confirm('Archive this classroom?')">Archive</button>
                                </form>
                            }
                            else
                            {
                                <form asp-action="Restore" asp-route-id="@item.Id" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button class="btn btn-sm btn-outline-success">Restore</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
