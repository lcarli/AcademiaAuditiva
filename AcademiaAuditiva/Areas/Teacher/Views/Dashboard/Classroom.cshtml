@model AcademiaAuditiva.Areas.Teacher.Models.ClassroomDashboardViewModel
@{
    ViewData["Title"] = $"Dashboard — {Model.ClassroomName}";
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h3 mb-0">@Model.ClassroomName</h1>
        <small class="text-muted">Classroom dashboard</small>
    </div>
    <a class="btn btn-link" asp-controller="Classrooms" asp-action="Details" asp-route-id="@Model.ClassroomId">
        Back to classroom
    </a>
</div>

<div class="row g-3 mb-4">
    <div class="col-sm-6 col-lg-3">
        <div class="card border-0 shadow-sm h-100"><div class="card-body">
            <div class="text-muted small">Students</div>
            <div class="h3 mb-0">@Model.Rows.Count</div>
        </div></div>
    </div>
    <div class="col-sm-6 col-lg-3">
        <div class="card border-0 shadow-sm h-100"><div class="card-body">
            <div class="text-muted small">Active (30d)</div>
            <div class="h3 mb-0">@Model.ActiveStudentsLast30Days</div>
        </div></div>
    </div>
    <div class="col-sm-6 col-lg-3">
        <div class="card border-0 shadow-sm h-100"><div class="card-body">
            <div class="text-muted small">Total attempts</div>
            <div class="h3 mb-0">@Model.TotalAttempts.ToString("N0")</div>
        </div></div>
    </div>
    <div class="col-sm-6 col-lg-3">
        <div class="card border-0 shadow-sm h-100"><div class="card-body">
            <div class="text-muted small">Avg accuracy</div>
            <div class="h3 mb-0">@Model.AverageAccuracy.ToString("F1")%</div>
        </div></div>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white"><strong>Per student</strong></div>
    <div class="table-responsive">
        <table class="table mb-0 align-middle">
            <thead class="table-light">
                <tr>
                    <th>Student</th>
                    <th class="text-end">Sessions</th>
                    <th class="text-end">Attempts</th>
                    <th class="text-end">Accuracy</th>
                    <th>Last activity</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var r in Model.Rows)
            {
                <tr>
                    <td>
                        <div>@r.Display</div>
                        <small class="text-muted">@r.Email</small>
                    </td>
                    <td class="text-end">@r.Sessions</td>
                    <td class="text-end">@r.Attempts.ToString("N0")</td>
                    <td class="text-end">@r.Accuracy.ToString("F1")%</td>
                    <td>
                        @if (r.LastActivity.HasValue) { @r.LastActivity.Value.ToString("yyyy-MM-dd HH:mm") }
                        else { <span class="text-muted">never</span> }
                    </td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-outline-primary"
                           asp-action="Student" asp-route-id="@r.StudentId" asp-route-classroomId="@Model.ClassroomId">View</a>
                    </td>
                </tr>
            }
            @if (!Model.Rows.Any())
            {
                <tr><td colspan="6" class="text-muted text-center py-4">No students in this classroom yet.</td></tr>
            }
            </tbody>
        </table>
    </div>
</div>
