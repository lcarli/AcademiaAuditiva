@model AcademiaAuditiva.Models.Teaching.Routine
@{
    ViewData["Title"] = Model.Name;
    var assignments = (List<AcademiaAuditiva.Models.Teaching.RoutineAssignment>)ViewBag.Assignments;
}

<div class="d-flex flex-wrap justify-content-between align-items-start gap-2 mb-4">
    <div>
        <h1 class="h3 fw-bold mb-1 text-body-emphasis">@Model.Name</h1>
        @if (!string.IsNullOrEmpty(Model.Description)) { <p class="text-secondary mb-0">@Model.Description</p> }
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <a class="btn btn-outline-secondary btn-sm" asp-action="Edit" asp-route-id="@Model.Id">
            <i class="bi bi-pencil me-1" aria-hidden="true"></i>@Localizer["Teacher.Routines.Edit"]
        </a>
        <a class="btn aa-grad-btn btn-sm" asp-action="Assign" asp-route-routineId="@Model.Id">
            <i class="bi bi-person-check me-1" aria-hidden="true"></i>@Localizer["Teacher.Routines.Assign"]
        </a>
        <a class="btn btn-link btn-sm" asp-action="Index">@Localizer["Teacher.Routines.Back"]</a>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-7">
        <div class="aa-card-flat">
            <div class="card-header bg-transparent border-bottom border-body d-flex justify-content-between align-items-center gap-2 flex-wrap">
                <strong class="text-body-emphasis"><i class="bi bi-music-note-list me-1" aria-hidden="true"></i>@Localizer["Teacher.Routines.Exercises"] (@Model.Items.Count)</strong>
                <a class="btn btn-sm aa-grad-btn" asp-action="AddItem" asp-route-routineId="@Model.Id">
                    <i class="bi bi-plus-circle me-1" aria-hidden="true"></i>@Localizer["Teacher.Routines.AddExercise"]
                </a>
            </div>
            @if (!Model.Items.Any())
            {
                <div class="card-body text-secondary">@Localizer["Teacher.Routines.NoExercisesYet"]</div>
            }
            else
            {
                <ol class="list-group list-group-flush list-group-numbered">
                    @foreach (var item in Model.Items.OrderBy(i => i.Order))
                    {
                        var exName = item.Exercise?.Name ?? string.Empty;
                        var locName = Localizer[exName];
                        var displayName = locName.IsResourceNotFound ? exName : locName.Value;
                        <li class="list-group-item d-flex justify-content-between align-items-start gap-2 flex-wrap">
                            <div>
                                <div><strong>@displayName</strong></div>
                                <div class="small text-secondary">
                                    @Localizer["Teacher.Routines.Target"]: @item.TargetCount
                                    @if (item.MinScore.HasValue) { <text>· @Localizer["Teacher.Routines.MinScore"]: @item.MinScore</text> }
                                    @if (!string.IsNullOrEmpty(item.FilterJson)) { <text>· @Localizer["Teacher.Routines.CustomFilter"]</text> }
                                </div>
                            </div>
                            <div class="d-flex gap-1">
                                <a class="btn btn-sm btn-outline-secondary" asp-action="EditItem" asp-route-routineId="@Model.Id" asp-route-itemId="@item.Id">@Localizer["Teacher.Routines.Edit"]</a>
                                <form asp-action="RemoveItem" method="post"
                                      onsubmit="return confirm('@Localizer["Teacher.Routines.RemoveItemConfirm"].Value');">
                                    <input type="hidden" name="routineId" value="@Model.Id" />
                                    <input type="hidden" name="itemId" value="@item.Id" />
                                    <button class="btn btn-sm btn-outline-danger" type="submit">@Localizer["Teacher.Routines.Remove"]</button>
                                </form>
                            </div>
                        </li>
                    }
                </ol>
            }
        </div>
    </div>
    <div class="col-lg-5">
        <div class="aa-card-flat">
            <div class="card-header bg-transparent border-bottom border-body">
                <strong class="text-body-emphasis"><i class="bi bi-people me-1" aria-hidden="true"></i>@Localizer["Teacher.Routines.Assignments"] (@assignments.Count)</strong>
            </div>
            @if (!assignments.Any())
            {
                <div class="card-body text-secondary small">@Localizer["Teacher.Routines.NotAssignedYet"]</div>
            }
            else
            {
                <ul class="list-group list-group-flush">
                    @foreach (var a in assignments)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center small gap-2 flex-wrap">
                            <span>
                                @if (a.ClassroomId != null) { <text>👥 @a.Classroom?.Name</text> }
                                else { <text>👤 @a.Student?.UserName</text> }
                                <div class="text-secondary">
                                    @Localizer["Teacher.Routines.Assigned"] @a.AssignedAt.ToString("yyyy-MM-dd")
                                    @if (a.DueAt.HasValue) { <text>· @Localizer["Teacher.Routines.Due"] @a.DueAt.Value.ToString("yyyy-MM-dd")</text> }
                                </div>
                            </span>
                            <form asp-action="Unassign" method="post"
                                  onsubmit="return confirm('@Localizer["Teacher.Routines.RemoveAssignmentConfirm"].Value');">
                                <input type="hidden" name="routineId" value="@Model.Id" />
                                <input type="hidden" name="assignmentId" value="@a.Id" />
                                <button class="btn btn-sm btn-link text-danger p-0" type="submit">@Localizer["Teacher.Routines.RemoveAssignment"]</button>
                            </form>
                        </li>
                    }
                </ul>
            }
        </div>

        <form asp-action="Delete" method="post" class="mt-3"
              onsubmit="return confirm('@Localizer["Teacher.Routines.DeleteConfirm"].Value');">
            <input type="hidden" name="id" value="@Model.Id" />
            <button class="btn btn-sm btn-outline-danger" type="submit">
                <i class="bi bi-trash me-1" aria-hidden="true"></i>@Localizer["Teacher.Routines.Delete"]
            </button>
        </form>
    </div>
</div>
