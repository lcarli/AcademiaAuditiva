@model AcademiaAuditiva.Models.Teaching.Routine
@{
    ViewData["Title"] = Model.Name;
    var assignments = (List<AcademiaAuditiva.Models.Teaching.RoutineAssignment>)ViewBag.Assignments;
}
@if (TempData["Success"] is string s) { <div class="alert alert-success">@s</div> }
@if (TempData["Error"] is string e) { <div class="alert alert-danger">@e</div> }

<div class="d-flex justify-content-between align-items-start mb-3">
    <div>
        <h1 class="h3 mb-1">@Model.Name</h1>
        @if (!string.IsNullOrEmpty(Model.Description)) { <p class="text-secondary mb-0">@Model.Description</p> }
    </div>
    <div class="d-flex gap-2">
        <a class="btn btn-outline-secondary" asp-action="Edit" asp-route-id="@Model.Id">Edit</a>
        <a class="btn btn-primary" asp-action="Assign" asp-route-routineId="@Model.Id">Assign</a>
        <a class="btn btn-link" asp-action="Index">Back</a>
    </div>
</div>

<div class="row g-3">
    <div class="col-lg-7">
        <div class="aa-card-flat shadow-sm">
            <div class="card-header bg-transparent border-bottom border-body d-flex justify-content-between align-items-center">
                <strong>Exercises (@Model.Items.Count)</strong>
                <a class="btn btn-sm btn-primary" asp-action="AddItem" asp-route-routineId="@Model.Id">Add exercise</a>
            </div>
            @if (!Model.Items.Any())
            {
                <div class="card-body text-secondary">No exercises yet.</div>
            }
            else
            {
                <ol class="list-group list-group-flush list-group-numbered">
                    @foreach (var item in Model.Items.OrderBy(i => i.Order))
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-start">
                            <div>
                                <div><strong>@item.Exercise?.Name</strong></div>
                                <div class="small text-secondary">
                                    target: @item.TargetCount
                                    @if (item.MinScore.HasValue) { <text>· min score: @item.MinScore</text> }
                                    @if (!string.IsNullOrEmpty(item.FilterJson)) { <text>· custom filter</text> }
                                </div>
                            </div>
                            <div class="d-flex gap-1">
                                <a class="btn btn-sm btn-outline-secondary"
                                   asp-action="EditItem" asp-route-routineId="@Model.Id" asp-route-itemId="@item.Id">Edit</a>
                                <form asp-action="RemoveItem" method="post"
                                      onsubmit="return confirm('Remove this exercise from the routine?');">
                                    <input type="hidden" name="routineId" value="@Model.Id" />
                                    <input type="hidden" name="itemId" value="@item.Id" />
                                    <button class="btn btn-sm btn-outline-danger" type="submit">Remove</button>
                                </form>
                            </div>
                        </li>
                    }
                </ol>
            }
        </div>
    </div>
    <div class="col-lg-5">
        <div class="aa-card-flat shadow-sm">
            <div class="card-header bg-transparent border-bottom border-body"><strong>Assignments (@assignments.Count)</strong></div>
            @if (!assignments.Any())
            {
                <div class="card-body text-secondary small">Not assigned to anyone yet.</div>
            }
            else
            {
                <ul class="list-group list-group-flush">
                    @foreach (var a in assignments)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center small">
                            <span>
                                @if (a.ClassroomId != null) { <text>👥 @a.Classroom?.Name</text> }
                                else { <text>👤 @a.Student?.UserName</text> }
                                <div class="text-secondary">
                                    assigned @a.AssignedAt.ToString("yyyy-MM-dd")
                                    @if (a.DueAt.HasValue) { <text>· due @a.DueAt.Value.ToString("yyyy-MM-dd")</text> }
                                </div>
                            </span>
                            <form asp-action="Unassign" method="post"
                                  onsubmit="return confirm('Remove this assignment?');">
                                <input type="hidden" name="routineId" value="@Model.Id" />
                                <input type="hidden" name="assignmentId" value="@a.Id" />
                                <button class="btn btn-sm btn-link text-danger p-0" type="submit">remove</button>
                            </form>
                        </li>
                    }
                </ul>
            }
        </div>

        <form asp-action="Delete" method="post" class="mt-3"
              onsubmit="return confirm('Delete this routine permanently?');">
            <input type="hidden" name="id" value="@Model.Id" />
            <button class="btn btn-sm btn-outline-danger" type="submit">Delete routine</button>
        </form>
    </div>
</div>
