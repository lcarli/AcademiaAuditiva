@model AcademiaAuditiva.Areas.Teacher.Models.InviteFormViewModel
@{
    var classroom = (AcademiaAuditiva.Models.Teaching.Classroom)ViewBag.Classroom;
    ViewData["Title"] = $"Invite student — {classroom.Name}";
}
<h1 class="h4 mb-3">Invite a student to @classroom.Name</h1>

<form asp-action="Invite" method="post" class="aa-card-flat shadow-sm" style="max-width: 480px;"
      x-data="{ submitting: false }"
      x-on:submit="submitting = true">
    <div class="card-body">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <input type="hidden" asp-for="ClassroomId" />
        <div class="mb-3">
            <label asp-for="Email" class="form-label"></label>
            <input asp-for="Email" class="form-control" autocomplete="off" placeholder="student@example.com"
                   x-bind:disabled="submitting" />
            <span asp-validation-for="Email" class="text-danger small"></span>
            <div class="form-text">
                If the student already has an account, they'll be added to your classroom on accept.
                Otherwise they'll receive a link to finish creating their account.
            </div>
        </div>
        <button type="submit" class="btn btn-primary" x-bind:disabled="submitting">
            <span x-show="!submitting">Send invitation</span>
            <span x-show="submitting" x-cloak>
                <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                Sending&hellip;
            </span>
        </button>
        <a class="btn btn-link" asp-controller="Classrooms" asp-action="Details" asp-route-id="@Model.ClassroomId">Cancel</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
