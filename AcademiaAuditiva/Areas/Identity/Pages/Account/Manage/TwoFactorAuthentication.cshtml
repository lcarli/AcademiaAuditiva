@page
@using Microsoft.AspNetCore.Http.Features
@model TwoFactorAuthenticationModel
@{
    ViewData["Title"] = Localizer["Manage.Tfa.Title"].Value;
    ViewData["ActivePage"] = ManageNavPages.TwoFactorAuthentication;
}

<partial name="_StatusMessage" for="StatusMessage" />
<h3 class="mb-3 text-body-emphasis">@ViewData["Title"]</h3>
@{
    var consentFeature = HttpContext.Features.Get<ITrackingConsentFeature>();
    @if (consentFeature?.CanTrack ?? true)
    {
        @if (Model.Is2faEnabled)
        {
            if (Model.RecoveryCodesLeft == 0)
            {
                <div class="alert alert-danger">
                    <strong>@Localizer["Manage.Tfa.NoCodes"]</strong>
                    <p class="mb-0">@Localizer["Manage.Tfa.NoCodesGenerate"]</p>
                </div>
            }
            else if (Model.RecoveryCodesLeft == 1)
            {
                <div class="alert alert-danger">
                    <strong>@Localizer["Manage.Tfa.OneCodeLeft"]</strong>
                    <p class="mb-0">@Localizer["Manage.Tfa.OneCodeGenerate"]</p>
                </div>
            }
            else if (Model.RecoveryCodesLeft <= 3)
            {
                <div class="alert alert-warning">
                    <strong>@string.Format(Localizer["Manage.Tfa.FewCodesLeft"].Value, Model.RecoveryCodesLeft)</strong>
                    <p class="mb-0">@Localizer["Manage.Tfa.FewCodesGenerate"]</p>
                </div>
            }

            if (Model.IsMachineRemembered)
            {
                <form method="post" class="d-inline">
                    <button type="submit" class="btn btn-outline-primary me-2">@Localizer["Manage.Tfa.ForgetBrowser"]</button>
                </form>
            }
            <a asp-page="./Disable2fa" class="btn btn-outline-danger me-2">@Localizer["Manage.Tfa.Disable"]</a>
            <a asp-page="./GenerateRecoveryCodes" class="btn btn-outline-primary">@Localizer["Manage.Tfa.ResetCodes"]</a>
        }

        <h4 class="mt-4 text-body-emphasis">@Localizer["Manage.Tfa.AppHeader"]</h4>
        @if (!Model.HasAuthenticator)
        {
            <a id="enable-authenticator" asp-page="./EnableAuthenticator" class="btn aa-grad-btn">@Localizer["Manage.Tfa.AddApp"]</a>
        }
        else
        {
            <a id="enable-authenticator" asp-page="./EnableAuthenticator" class="btn aa-grad-btn me-2">@Localizer["Manage.Tfa.SetupApp"]</a>
            <a id="reset-authenticator" asp-page="./ResetAuthenticator" class="btn btn-outline-danger">@Localizer["Manage.Tfa.ResetApp"]</a>
        }
    }
    else
    {
        <div class="alert alert-danger">
            <strong>@Localizer["Manage.Tfa.PrivacyDenied"]</strong>
            <p class="mb-0">@Localizer["Manage.Tfa.PrivacyDeniedBody"]</p>
        </div>
    }
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
