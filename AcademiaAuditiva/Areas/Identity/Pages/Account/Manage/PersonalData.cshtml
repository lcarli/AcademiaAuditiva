@page
@model PersonalDataModel
@{
    ViewData["Title"] = Localizer["Manage.PersonalData.Title"].Value;
    ViewData["ActivePage"] = ManageNavPages.PersonalData;
}

<h3 class="mb-3 text-body-emphasis">@ViewData["Title"]</h3>

<div class="row">
    <div class="col-md-8">
        <p class="text-secondary">@Localizer["Manage.PersonalData.Body"]</p>
        <p>
            <strong>@Localizer["Manage.PersonalData.Warning"]</strong>
        </p>
        <form id="download-data" asp-page="DownloadPersonalData" method="post" class="d-inline">
            <button class="btn btn-outline-primary" type="submit"><i class="bi bi-download me-1" aria-hidden="true"></i>@Localizer["Manage.PersonalData.Download"]</button>
        </form>
        <a id="delete" asp-page="DeletePersonalData" class="btn btn-outline-danger ms-2"><i class="bi bi-trash me-1" aria-hidden="true"></i>@Localizer["Manage.PersonalData.Delete"]</a>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
