@{
    if (ViewData.TryGetValue("ParentLayout", out var parentLayout) && parentLayout != null)
    {
        Layout = parentLayout.ToString();
    }
    else
    {
        Layout = "/Views/Shared/_Layout.cshtml";
    }
}

<div class="d-flex flex-column gap-1 mb-4">
    <h1 class="h3 fw-bold mb-0 text-body-emphasis">@Localizer["Manage.Title"]</h1>
    <p class="text-secondary mb-0">@Localizer["Manage.Subtitle"]</p>
</div>

<div class="row g-4">
    <div class="col-lg-3">
        <div class="aa-card-flat p-2">
            <partial name="_ManageNav" />
        </div>
    </div>
    <div class="col-lg-9">
        <div class="aa-card-flat p-4">
            @RenderBody()
        </div>
    </div>
</div>

@section Scripts {
    @RenderSection("Scripts", required: false)
}
