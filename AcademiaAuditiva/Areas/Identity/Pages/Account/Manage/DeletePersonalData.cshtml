@page
@model DeletePersonalDataModel
@{
    ViewData["Title"] = Localizer["Manage.DeletePersonal.Title"].Value;
    ViewData["ActivePage"] = ManageNavPages.PersonalData;
}

<h3 class="mb-3 text-body-emphasis">@ViewData["Title"]</h3>

<div class="alert alert-warning" role="alert">
    <p class="mb-0">
        <strong>@Localizer["Manage.DeletePersonal.Warning"]</strong>
    </p>
</div>

<div>
    <form id="delete-user" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
        @if (Model.RequirePassword)
        {
            <div class="form-floating mb-3" style="max-width: 480px;">
                <input asp-for="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" placeholder="@Localizer["Manage.DeletePersonal.PasswordPlaceholder"]" />
                <label asp-for="Input.Password" class="form-label">@Localizer["Manage.DeletePersonal.PasswordLabel"]</label>
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>
        }
        <button class="btn btn-danger" type="submit"><i class="bi bi-trash me-1" aria-hidden="true"></i>@Localizer["Manage.DeletePersonal.Submit"]</button>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
