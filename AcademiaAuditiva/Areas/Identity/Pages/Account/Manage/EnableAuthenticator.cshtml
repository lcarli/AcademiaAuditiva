@page
@model EnableAuthenticatorModel
@{
    ViewData["Title"] = Localizer["Manage.EnableAuth.Title"].Value;
    ViewData["ActivePage"] = ManageNavPages.TwoFactorAuthentication;
}

<partial name="_StatusMessage" for="StatusMessage" />
<h3 class="mb-3 text-body-emphasis">@ViewData["Title"]</h3>
<div>
    <p>@Localizer["Manage.EnableAuth.Intro"]</p>
    <ol class="list">
        <li>
            <p>@Localizer["Manage.EnableAuth.Step1"]</p>
        </li>
        <li>
            <p>@Html.Raw(string.Format(Localizer["Manage.EnableAuth.Step2"].Value, "<kbd>" + Model.SharedKey + "</kbd>"))</p>
            <div class="alert alert-info">@Localizer["Manage.EnableAuth.QRHelp"]</div>
            <div id="qrCode"></div>
            <div id="qrCodeData" data-url="@Model.AuthenticatorUri"></div>
        </li>
        <li>
            <p>@Localizer["Manage.EnableAuth.Step3"]</p>
            <div class="row">
                <div class="col-md-8">
                    <form id="send-code" method="post">
                        <div class="form-floating mb-3">
                            <input asp-for="Input.Code" class="form-control" autocomplete="off" placeholder="@Localizer["Manage.EnableAuth.CodePlaceholder"]" />
                            <label asp-for="Input.Code" class="control-label form-label">@Localizer["Manage.EnableAuth.CodeLabel"]</label>
                            <span asp-validation-for="Input.Code" class="text-danger"></span>
                        </div>
                        <button type="submit" class="btn aa-grad-btn">@Localizer["Manage.EnableAuth.Verify"]</button>
                        <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
                    </form>
                </div>
            </div>
        </li>
    </ol>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
