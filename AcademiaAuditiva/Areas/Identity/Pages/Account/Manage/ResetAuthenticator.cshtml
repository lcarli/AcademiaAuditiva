@page
@model ResetAuthenticatorModel
@{
    ViewData["Title"] = Localizer["Manage.ResetAuth.Title"].Value;
    ViewData["ActivePage"] = ManageNavPages.TwoFactorAuthentication;
}

<partial name="_StatusMessage" for="StatusMessage" />
<h3 class="mb-3 text-body-emphasis">@ViewData["Title"]</h3>
<div class="alert alert-warning" role="alert">
    <p>
        <i class="bi bi-exclamation-triangle me-1" aria-hidden="true"></i>
        <strong>@Localizer["Manage.ResetAuth.Warning"]</strong>
    </p>
    <p class="mb-0">@Localizer["Manage.ResetAuth.Body"]</p>
</div>
<div>
    <form id="reset-authenticator-form" method="post">
        <button id="reset-authenticator-button" class="btn btn-danger" type="submit">@Localizer["Manage.ResetAuth.Submit"]</button>
    </form>
</div>
