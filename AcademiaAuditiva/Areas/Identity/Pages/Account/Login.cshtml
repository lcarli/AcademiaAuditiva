@page
@model LoginModel

@{
    ViewData["Title"] = Localizer["Login.Login"].Value;
}

<div class="row justify-content-center">
    <div class="col-md-7 col-lg-5">
        <div class="aa-card-flat p-4 p-md-5">
            <header class="text-center mb-4">
                <span class="aa-badge-soft">@Localizer["Identity.Auth.Welcome"]</span>
                <h1 class="display-6 fw-bold mt-2 mb-0 text-body-emphasis">@Localizer["Login.Title"]</h1>
            </header>
            <form id="account" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3" role="alert"></div>
                <div class="form-floating mb-3">
                    <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                    <label asp-for="Input.Email" class="form-label">Email</label>
                    <span asp-validation-for="Input.Email" class="text-danger small"></span>
                </div>
                <div class="form-floating mb-3">
                    <input asp-for="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" placeholder="@Localizer["Register.Password"]" />
                    <label asp-for="Input.Password" class="form-label">@Localizer["Register.Password"]</label>
                    <span asp-validation-for="Input.Password" class="text-danger small"></span>
                </div>
                <div class="form-check mb-3">
                    <input class="form-check-input" asp-for="Input.RememberMe" />
                    <label class="form-check-label" asp-for="Input.RememberMe">@Localizer["Login.RememberMe"]</label>
                </div>
                <button id="login-submit" type="submit" class="w-100 btn btn-lg aa-grad-btn mb-3">@Localizer["Login.Login"]</button>
                <div class="d-flex flex-column gap-1 small">
                    <a id="forgot-password" asp-page="./ForgotPassword">@Localizer["Login.Remember"]</a>
                    <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">@Localizer["Login.RegisterText"]</a>
                    <a id="resend-confirmation" asp-page="./ResendEmailConfirmation">@Localizer["Login.ResendEmail"]</a>
                </div>
            </form>
            @if ((Model.ExternalLogins?.Count ?? 0) > 0)
            {
                <hr class="my-4" />
                <p class="text-secondary small text-center mb-2">@Localizer["Identity.Auth.OrExternal"]</p>
                <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                    <div class="d-flex flex-wrap gap-2 justify-content-center">
                        @foreach (var provider in Model.ExternalLogins!)
                        {
                            <button type="submit" class="btn btn-outline-secondary" name="provider" value="@provider.Name" title="@Localizer["Login.ExternalLoginText"] @provider.DisplayName">@provider.DisplayName</button>
                        }
                    </div>
                </form>
            }
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
