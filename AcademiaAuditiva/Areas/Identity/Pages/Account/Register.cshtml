@page
@model RegisterModel
@{
    ViewData["Title"] = Localizer["Register.Header"].Value;
}

<div class="row justify-content-center">
    <div class="col-md-7 col-lg-6">
        <div class="aa-card-flat p-4 p-md-5">
            <header class="text-center mb-4">
                <span class="aa-badge-soft">@Localizer["Identity.Auth.JoinTitle"]</span>
                <h1 class="display-6 fw-bold mt-2 mb-0 text-body-emphasis">@Localizer["Register.Title"]</h1>
            </header>
            <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3" role="alert"></div>
                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="form-floating">
                            <input asp-for="Input.FirstName" class="form-control" placeholder="First name" />
                            <label asp-for="Input.FirstName"></label>
                            <span asp-validation-for="Input.FirstName" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-floating">
                            <input asp-for="Input.LastName" class="form-control" placeholder="Last name" />
                            <label asp-for="Input.LastName"></label>
                            <span asp-validation-for="Input.LastName" class="text-danger small"></span>
                        </div>
                    </div>
                </div>
                <div class="form-floating mt-3 mb-3">
                    <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                    <label asp-for="Input.Email">Email</label>
                    <span asp-validation-for="Input.Email" class="text-danger small"></span>
                </div>
                <div class="form-floating mb-3">
                    <input asp-for="Input.Password" class="form-control" autocomplete="new-password" aria-required="true" placeholder="@Localizer["Register.Password"]" />
                    <label asp-for="Input.Password">@Localizer["Register.Password"]</label>
                    <span asp-validation-for="Input.Password" class="text-danger small"></span>
                </div>
                <div class="form-floating mb-3">
                    <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" aria-required="true" placeholder="@Localizer["Register.PasswordConfirmation"]" />
                    <label asp-for="Input.ConfirmPassword">@Localizer["Register.PasswordConfirmation"]</label>
                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                </div>
                <button id="registerSubmit" type="submit" class="w-100 btn btn-lg aa-grad-btn">@Localizer["Register.Header"]</button>
            </form>
            @if ((Model.ExternalLogins?.Count ?? 0) > 0)
            {
                <hr class="my-4" />
                <p class="text-secondary small text-center mb-2">@Localizer["Register.Text"]</p>
                <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                    <div class="d-flex flex-wrap gap-2 justify-content-center">
                        @foreach (var provider in Model.ExternalLogins!)
                        {
                            <button type="submit" class="btn btn-outline-secondary" name="provider" value="@provider.Name">@provider.DisplayName</button>
                        }
                    </div>
                </form>
            }
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
