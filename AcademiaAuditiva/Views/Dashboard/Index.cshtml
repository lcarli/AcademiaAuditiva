@{
    ViewBag.Title = Localizer["Dashboard.Title"].Value;
}

<header class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-4">
    <div>
        <span class="aa-badge-soft">@Localizer["Dashboard.Title"]</span>
        <h1 class="display-6 fw-bold mt-2 mb-1 text-body-emphasis">
            @Localizer["Dashboard.WelcomeMessage"] <span class="aa-brand-text">@ViewBag.FirstName</span>!
        </h1>
        <p class="text-secondary mb-0">@Localizer["Dashboard.Subtitle"]</p>
    </div>
    <a class="btn aa-grad-btn" asp-controller="Exercise" asp-action="Index">
        <i class="bi bi-play-circle me-2" aria-hidden="true"></i>@Localizer["Dashboard.StartTraining"]
    </a>
</header>

<!-- KPIs -->
<div class="row row-cols-1 row-cols-md-3 g-4 mb-4">
    <div class="col">
        <div class="aa-card aa-card-accent p-4 h-100">
            <div class="d-flex align-items-center gap-3">
                <span class="aa-icon-pill" aria-hidden="true"><i class="bi bi-music-note-list"></i></span>
                <div>
                    <h6 class="text-uppercase small text-secondary mb-1">@Localizer["Dashboard.TotalExercises"]</h6>
                    <h3 class="fw-bold mb-0 text-body-emphasis">@ViewBag.TotalExercises</h3>
                </div>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="aa-card aa-card-accent p-4 h-100">
            <div class="d-flex align-items-center gap-3">
                <span class="aa-icon-pill" aria-hidden="true" style="color:#f59e0b;"><i class="bi bi-trophy"></i></span>
                <div>
                    <h6 class="text-uppercase small text-secondary mb-1">@Localizer["Dashboard.BestScore"]</h6>
                    <h3 class="fw-bold mb-0 text-body-emphasis">@ViewBag.BestScore</h3>
                </div>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="aa-card aa-card-accent p-4 h-100">
            <div class="d-flex align-items-center gap-3">
                <span class="aa-icon-pill" aria-hidden="true" style="color:#14b8a6;"><i class="bi bi-stopwatch"></i></span>
                <div>
                    <h6 class="text-uppercase small text-secondary mb-1">@Localizer["Dashboard.TotalTime"]</h6>
                    <h3 class="fw-bold mb-0 text-body-emphasis">@ViewBag.TotalTime <small class="fs-6 text-secondary">min</small></h3>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Charts -->
<div class="row row-cols-1 row-cols-lg-2 g-4">
    <div class="col">
        <div class="aa-card-flat p-4 h-100">
            <h5 class="mb-3 d-flex align-items-center gap-2 text-body-emphasis">
                <i class="bi bi-graph-up text-primary" aria-hidden="true"></i>@Localizer["Dashboard.LearningTimeline"]
            </h5>
            <canvas id="learningTimelineChart" height="120"></canvas>
        </div>
    </div>
    <div class="col">
        <div class="aa-card-flat p-4 h-100">
            <h5 class="mb-3 d-flex align-items-center gap-2 text-body-emphasis">
                <i class="bi bi-bar-chart" aria-hidden="true" style="color:#7c3aed"></i>@Localizer["Dashboard.ByDifficulty"]
            </h5>
            <canvas id="difficultyChart" height="120"></canvas>
        </div>
    </div>
    <div class="col">
        <div class="aa-card-flat p-4 h-100">
            <h5 class="mb-3 d-flex align-items-center gap-2 text-body-emphasis">
                <i class="bi bi-radar" aria-hidden="true" style="color:#3b82f6"></i>@Localizer["Dashboard.TechnicalSkills"]
            </h5>
            <canvas id="radarTechnicalChart" height="180"></canvas>
        </div>
    </div>
    <div class="col">
        <div class="aa-card-flat p-4 h-100">
            <h5 class="mb-3 d-flex align-items-center gap-2 text-body-emphasis">
                <i class="bi bi-pie-chart" aria-hidden="true" style="color:#ec4899"></i>@Localizer["Dashboard.PedagogicalCategories"]
            </h5>
            <canvas id="radarCategoryChart" height="180"></canvas>
        </div>
    </div>
</div>

<!-- Recent sessions -->
<div class="aa-card-flat p-4 mt-4">
    <h5 class="mb-3 d-flex align-items-center gap-2 text-body-emphasis">
        <i class="bi bi-clock-history" aria-hidden="true" style="color:#14b8a6"></i>@Localizer["Dashboard.RecentSessions"]
    </h5>
    <div class="table-responsive">
        <table class="table table-sm align-middle mb-0">
            <thead>
                <tr class="text-secondary small text-uppercase">
                    <th>@Localizer["Dashboard.Exercise"]</th>
                    <th>@Localizer["Dashboard.Date"]</th>
                    <th>@Localizer["Dashboard.Correct"]</th>
                    <th>@Localizer["Dashboard.Errors"]</th>
                    <th>@Localizer["Dashboard.TimeSpent"]</th>
                    <th>@Localizer["Dashboard.Score"]</th>
                </tr>
            </thead>
            <tbody id="scoreHistoryTable"></tbody>
        </table>
    </div>
</div>

<!-- Difficulties + Recommendations -->
<div class="row row-cols-1 row-cols-lg-2 g-4 mt-2">
    <div class="col">
        <div class="aa-card-flat p-4 h-100">
            <h5 class="mb-3 d-flex align-items-center gap-2 text-body-emphasis">
                <i class="bi bi-exclamation-triangle text-warning" aria-hidden="true"></i>@Localizer["Dashboard.MostMissedItems"]
            </h5>
            <ul class="list-group list-group-flush" id="mostMissedList"></ul>
        </div>
    </div>
    <div class="col">
        <div class="aa-card-flat p-4 h-100">
            <h5 class="mb-3 d-flex align-items-center gap-2 text-body-emphasis">
                <i class="bi bi-lightbulb" aria-hidden="true" style="color:#7c3aed"></i>@Localizer["Dashboard.Recommendations"]
            </h5>
            <div id="recommendationsList" class="list-group list-group-flush"></div>
        </div>
    </div>
</div>

<div id="localizer"
     data-chart-progress="@Localizer["Dashboard.ChartProgress"]"
     data-chart-accuracy-by-skill="@Localizer["Dashboard.ChartAccuracyBySkill"]"
     data-chart-accuracy-by-category="@Localizer["Dashboard.ChartAccuracyByCategory"]"
     data-chart-accuracy-by-difficulty="@Localizer["Dashboard.ChartAccuracyByDifficulty"]"
     data-diff-Beginner="@Localizer["Exercise.Beginner"]"
     data-diff-Intermediate="@Localizer["Exercise.Intermediate"]"
     data-diff-Advanced="@Localizer["Exercise.Advanced"]"></div>

@{
    var skillNames = new[] { "NoteRecognition", "ChordRecognition", "IntervalRecognition", "FunctionRecognition", "MelodyReproduction", "RhythmPatterns", "HarmonicField", "ScaleRecognition" };
    var categoryNames = new[] { "Harmony", "Melody", "Rhythm", "EarTraining", "Scales", "Games", "Misc" };
    var exerciseNames = new[] { "GuessNote", "GuessChords", "GuessInterval", "GuessQuality", "GuessFunction", "GuessFullInterval", "GuessMissingNote", "IntervalMelodico", "SolfegeMelody" };
}
<script id="aa-i18n-map" type="application/json">
{
    "skills": {
        @for (var i = 0; i < skillNames.Length; i++)
        {
            var name = skillNames[i];
            <text>"@name": "@Localizer["ExerciseType." + name].Value"@(i < skillNames.Length - 1 ? "," : "")</text>
        }
    },
    "categories": {
        @for (var i = 0; i < categoryNames.Length; i++)
        {
            var name = categoryNames[i];
            <text>"@name": "@Localizer["ExerciseCategory." + name].Value"@(i < categoryNames.Length - 1 ? "," : "")</text>
        }
    },
    "exercises": {
        @for (var i = 0; i < exerciseNames.Length; i++)
        {
            var name = exerciseNames[i];
            <text>"@name": "@Localizer[name].Value"@(i < exerciseNames.Length - 1 ? "," : "")</text>
        }
    }
}
</script>


@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        let exerciseTranslations = {};
        let aaI18n = { skills: {}, categories: {}, exercises: {} };
        try {
            const raw = document.getElementById('aa-i18n-map')?.textContent;
            if (raw) aaI18n = JSON.parse(raw);
            exerciseTranslations = aaI18n.exercises || {};
        } catch (e) { console.warn('aa-i18n-map parse failed', e); }
        const tSkill = k => aaI18n.skills[k] || k;
        const tCat = k => aaI18n.categories[k] || k;
        const tExercise = k => aaI18n.exercises[k] || exerciseTranslations[k] || k;

        document.addEventListener("DOMContentLoaded", () => {
            const loc = document.getElementById("localizer")?.dataset;

            // Override exerciseTranslations from server endpoint (if it returns more keys),
            // but keep our pre-translated map as fallback for any missing entries.
            fetch("/Dashboard/GetExerciseTranslations")
                .then(res => res.json())
                .then(data => {
                    exerciseTranslations = Object.assign({}, aaI18n.exercises || {}, data || {});
                })
                .catch(() => {});

            fetch("/Dashboard/GetUserTimeline")
                .then(res => res.json())
                .then(data => {
                    const ctx = document.getElementById("learningTimelineChart");
                    const labels = data.map(d => d.date);
                    const scores = data.map(d => d.score);

                    new Chart(ctx, {
                        type: 'line',
                        data: {
                            labels: labels,
                            datasets: [{
                                label: loc.chartProgress,
                                data: scores,
                                fill: true,
                                backgroundColor: 'rgba(124, 58, 237, 0.1)',
                                borderColor: 'rgba(124, 58, 237, 1)',
                                tension: 0.3
                            }]
                        },
                        options: {
                            responsive: true,
                            scales: {
                                y: { beginAtZero: true }
                            }
                        }
                    });
                });

            // Radar técnico
            fetch("/Dashboard/GetUserProgress")
                .then(res => res.json())
                .then(data => {
                    const radarCtx = document.getElementById("radarTechnicalChart");
                    const labels = Object.keys(data.radar).map(tSkill);
                    const values = Object.values(data.radar);

                    new Chart(radarCtx, {
                        type: 'radar',
                        data: {
                            labels: labels,
                            datasets: [{
                                label: loc.chartAccuracyBySkill,
                                data: values,
                                backgroundColor: 'rgba(124, 58, 237, 0.2)',
                                borderColor: 'rgba(124, 58, 237, 1)',
                                borderWidth: 1
                            }]
                        },
                        options: {
                            responsive: true,
                            scales: {
                                r: { min: 0, max: 100 }
                            }
                        }
                    });

                    const radarCat = document.getElementById("radarCategoryChart");
                    const catLabels = Object.keys(data.byCategory).map(tCat);
                    const catValues = Object.values(data.byCategory);

                    new Chart(radarCat, {
                        type: 'radar',
                        data: {
                            labels: catLabels,
                            datasets: [{
                                label: loc.chartAccuracyByCategory,
                                data: catValues,
                                backgroundColor: 'rgba(20, 184, 166, 0.2)',
                                borderColor: 'rgba(20, 184, 166, 1)',
                                borderWidth: 1
                            }]
                        },
                        options: {
                            responsive: true,
                            scales: {
                                r: { min: 0, max: 100 }
                            }
                        }
                    });
                });

            // Histórico
            fetch("/Dashboard/GetScoreHistory")
                .then(res => res.json())
                .then(data => {
                    const tbody = document.getElementById("scoreHistoryTable");
                    data.forEach(row => {
                        const tr = document.createElement("tr");
                        tr.innerHTML = `
                                <td>${tExercise(row.exercise)}</td>
                                <td>${row.date}</td>
                                <td><span class="text-success fw-semibold">${row.correct}</span></td>
                                <td><span class="text-danger fw-semibold">${row.error}</span></td>
                                <td>${row.timeSpent}</td>
                                <td><span class="aa-badge-soft">${row.score}</span></td>
                            `;
                        tbody.appendChild(tr);
                    });
                });

            // Dificuldade
            fetch("/Dashboard/GetPerformanceByDifficulty")
                .then(res => res.json())
                .then(data => {
                    const ctx = document.getElementById("difficultyChart");
                    const values = data.map(d => d.accuracy);

                    const labelMap = {
                        beginner: loc.diffBeginner,
                        intermediate: loc.diffIntermediate,
                        advanced: loc.diffAdvanced
                    };
                    const labels = data.map(d => labelMap[d.difficulty.toLowerCase()] ?? d.difficulty);

                    new Chart(ctx, {
                        type: 'bar',
                        data: {
                            labels: labels,
                            datasets: [{
                                label: loc.chartAccuracyByDifficulty,
                                data: values,
                                backgroundColor: 'rgba(124, 58, 237, 0.6)',
                                borderColor: 'rgba(124, 58, 237, 1)',
                                borderWidth: 1
                            }]
                        },
                        options: {
                            responsive: true,
                            scales: {
                                y: { beginAtZero: true, max: 100 }
                            }
                        }
                    });
                });

            // Maiores dificuldades
            fetch("/Dashboard/GetMostMissedItems")
                .then(res => res.json())
                .then(data => {
                    const list = document.getElementById("mostMissedList");
                    data.forEach(item => {
                        const li = document.createElement("li");
                        li.classList.add("list-group-item", "d-flex", "justify-content-between", "align-items-center", "border-0", "px-0");
                        li.innerHTML = `<span>${tExercise(item.exercise)}</span> <span class="badge bg-danger-subtle text-danger-emphasis">${item.errors}</span>`;
                        list.appendChild(li);
                    });
                });

            // Recomendações
            fetch("/Dashboard/GetRecommendations")
                .then(res => res.json())
                .then(data => {
                    const list = document.getElementById("recommendationsList");
                    data.forEach(msg => {
                        const div = document.createElement("div");
                        div.classList.add("list-group-item", "border-0", "px-0", "d-flex", "align-items-start", "gap-2");
                        div.innerHTML = `<i class="bi bi-arrow-right-circle text-primary mt-1"></i><span>${msg}</span>`;
                        list.appendChild(div);
                    });
                });
        });
    </script>
}
