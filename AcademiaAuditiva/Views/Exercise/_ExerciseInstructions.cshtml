@model AcademiaAuditiva.ViewModels.ExerciseViewModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<AcademiaAuditiva.Resources.SharedResources> S
@{
    // Prefer localized "Exercise.<Name>.Instructions" / ".TipN" keys.
    // Fall back to the legacy DB-stored Portuguese strings when a key is missing.
    var instrLocalized = S[$"Exercise.{Model.Title}.Instructions"];
    var instructions = instrLocalized.ResourceNotFound ? Model.Instructions : instrLocalized.Value;

    var localizedTips = new List<string>();
    for (var i = 1; i <= 8; i++)
    {
        var tip = S[$"Exercise.{Model.Title}.Tip{i}"];
        if (tip.ResourceNotFound) break;
        localizedTips.Add(tip.Value);
    }
    var tips = localizedTips.Count > 0 ? localizedTips : (Model.Tips ?? new List<string>());
}

<div class="aa-card-flat p-3">
    @if (!string.IsNullOrEmpty(instructions))
    {
        <h5 class="mb-3 d-flex align-items-center gap-2 text-body-emphasis">
            <i class="bi bi-lightbulb-fill text-warning" aria-hidden="true"></i>
            @Localizer["Instructions"]
        </h5>
        <p class="mb-2">@instructions</p>
    }

    @if (tips.Any())
    {
        <div class="bg-body-tertiary rounded p-3 mt-3">
            <strong class="text-body-emphasis">@Localizer["Tips"]:</strong>
            <ul class="mb-0 mt-1">
                @foreach (var tip in tips)
                {
                    <li>@tip</li>
                }
            </ul>
        </div>
    }
</div>
