@{
    ViewData["Title"] = "Wrong account";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="container py-5" style="max-width: 560px;">
    <h1 class="h3">This invitation is for a different email</h1>
    <p>
        You're signed in as <strong>@ViewBag.ActualEmail</strong>, but this invitation
        was sent to <strong>@ViewBag.ExpectedEmail</strong>.
    </p>
    <p class="text-muted">
        Please sign out and sign in (or register) using the invited email,
        then click the invitation link again.
    </p>
    <form asp-area="Identity" asp-page="/Account/Logout" method="post" class="d-inline">
        <button type="submit" class="btn btn-outline-secondary">Sign out</button>
    </form>
    <a class="btn btn-link" asp-controller="Home" asp-action="Index">Home</a>
</div>
