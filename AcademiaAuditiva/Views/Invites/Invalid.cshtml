@{
    ViewData["Title"] = "Invitation invalid";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="container py-5" style="max-width: 520px;">
    <h1 class="h3">This invitation isn't valid</h1>
    <p class="text-muted">
        The link is missing, has already been used, or has expired.
        Please ask your teacher to send you a new invitation.
    </p>
    <a class="btn btn-primary" asp-controller="Home" asp-action="Index">Go home</a>
</div>
