  <data name="Home.Exercises.Title" xml:space="preserve">
    <value>Six tools, one finely-tuned ear</value>
  </data>
  <data name="Home.Exercise1.Title" xml:space="preserve">
    <value>Note Perception</value>
  </data>
  <data name="Home.Exercise1.Desc" xml:space="preserve">
    <value>Identify isolated notes with growing precision. Start with naturals, advance to chromatics.</value>
  </data>
  <data name="Home.Exercise2.Title" xml:space="preserve">
    <value>Major and Minor Chords</value>
  </data>
  <data name="Home.Exercise2.Desc" xml:space="preserve">
    <value>Train recognition of each triad&apos;s color. Bright? Dark? Your ear decides.</value>
  </data>
  <data name="Home.Exercise3.Title" xml:space="preserve">
    <value>Melodic and Harmonic Intervals</value>
  </data>
  <data name="Home.Exercise3.Desc" xml:space="preserve">
    <value>From seconds to octaves, ascending, descending or simultaneous — master the grammar of melody.</value>
  </data>
  <data name="Home.Exercise4.Title" xml:space="preserve">
    <value>Chord Quality</value>
  </data>
  <data name="Home.Exercise4.Desc" xml:space="preserve">
    <value>Major, minor, diminished, augmented, with seventh... learn to distinguish each harmonic color.</value>
  </data>
  <data name="Home.Exercise5.Title" xml:space="preserve">
    <value>Harmonic Function</value>
  </data>
  <data name="Home.Exercise5.Desc" xml:space="preserve">
    <value>Tonic, subdominant, dominant. Hear progressions and name functions like a seasoned analyst.</value>
  </data>
  <data name="Home.Exercise6.Title" xml:space="preserve">
    <value>Rhythm Reading</value>
  </data>
  <data name="Home.Exercise6.Desc" xml:space="preserve">
    <value>Dictate rhythms, clap on time, read rhythmic cells — the foundation of all music.</value>
  </data>
