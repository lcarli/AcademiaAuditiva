  </data>
  <data name="Home.How.Step4.Title" xml:space="preserve">
    <value>Hit your goals</value>
  </data>
  <data name="Home.How.Step4.Desc" xml:space="preserve">
    <value>Unlock levels, complete tracks — and if you teach, follow your whole class.</value>
  </data>
  <data name="Home.Exercises.Badge" xml:space="preserve">
